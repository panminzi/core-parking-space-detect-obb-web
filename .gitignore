# Keep this file conservative: only ignore machine-local junk.
# Files required for the project to run on another device should stay trackable,
# except large generated training output that should not be versioned.

# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments and packaging leftovers
.venv/
.venv*/
web-flask/.venv312/
web-flask/.venv*/
venv/
env/
ENV/
pip-wheel-metadata/
*.egg-info/
build/
dist/

# Local environment files
.env
.env.local
.env.*.local
web-flask/users.json

# Runtime logs and temporary files
*.log
*.tmp
*.temp

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Large generated model output
other/model_train/detect_obb/output/
